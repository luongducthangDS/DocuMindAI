# DocuMind AI - Environment Variables
# Copy to .env and fill in real values. NEVER commit .env to git.

# LLM Providers
GROQ_API_KEY=gsk_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
GOOGLE_API_KEY=AIzaxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# LangSmith Observability
LANGCHAIN_TRACING_V2=true
LANGCHAIN_ENDPOINT=https://api.smith.langchain.com
LANGCHAIN_API_KEY=ls__xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
LANGCHAIN_PROJECT=documind-ai

# Hugging Face
HF_TOKEN=hf_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Vector store provider: "chroma" (mặc định, local) hoặc "qdrant" (Qdrant Cloud).
# Đổi provider chỉ cần đổi biến này, không sửa code (xem src/rag/vector_backend.py).
VECTOR_STORE_PROVIDER=chroma

# ChromaDB
CHROMA_HOST=
CHROMA_PORT=8000
CHROMA_COLLECTION=documind_legal

# Qdrant Cloud (chỉ cần khi VECTOR_STORE_PROVIDER=qdrant)
# Tạo cluster free tại https://cloud.qdrant.io, rồi:
#   python scripts/migrate_chroma_to_qdrant.py --verify
QDRANT_URL=
QDRANT_API_KEY=
QDRANT_COLLECTION=documind_legal

# FastAPI
API_HOST=0.0.0.0
API_PORT=8080
ENVIRONMENT=development
# ALLOWED_ORIGINS: khi deploy tách domain (Vercel frontend + Render backend),
# thêm domain Vercel production vào đây, vd:
# ALLOWED_ORIGINS=http://localhost:5174,https://documind-ai.vercel.app
ALLOWED_ORIGINS=http://localhost:5174,http://localhost:8080

# Email (for report delivery)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password-not-gmail-password

# Rate Limiting
RATE_LIMIT_PER_MINUTE=10

# Model Selection
PRIMARY_LLM=groq/llama-3.3-70b-versatile
FALLBACK_LLM=gemini/gemini-1.5-flash
EMBEDDING_MODEL=sentence-transformers/paraphrase-multilingual-MiniLM-L12-v2
INITIALIZE_RAG_ON_STARTUP=false
ENABLE_RERANKER=false

# Storage
DATA_DIR=./data
REPORTS_DIR=./reports
LOGS_DIR=./logs
SQLITE_DB=./data/documind.db

# Ingestion
MAX_UPLOAD_SIZE_MB=50
CHUNK_SIZE=512
CHUNK_OVERLAP=64
