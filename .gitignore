# Secrets — NEVER commit
.env
.env.*
!.env.example

# Raw / processed data (large files, not needed for deployment)
data/raw/
data/processed/

# Eval questions and benchmark results ARE committed (portfolio evidence)
# data/eval/   ← intentionally NOT ignored
# reports/     ← intentionally NOT ignored

# Runtime artifacts (generated at runtime, not source)
logs/
__pycache__/
*.pyc
*.pyo
*.pyd
.pytest_cache/
.ruff_cache/
*.egg-info/
dist/
build/
.coverage

# IDE
.idea/
.vscode/
*.swp

# Claude Code local settings
.claude/

# Test / temp data files
data/*.db
data/*.json
data/*.docx
data/*.html
data/*.js
