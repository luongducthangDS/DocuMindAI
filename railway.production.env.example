# Copy these values into Railway Variables.
# Do not paste real secrets into git. Rotate any key that was exposed in chat/logs.

ENVIRONMENT=production

# FastAPI is the public Railway service.
# It serves the React build at / and API routes under /api/v1.
API_HOST=127.0.0.1
API_PORT=8080

# Must match the model used to index data/chroma_db.
EMBEDDING_MODEL=sentence-transformers/paraphrase-multilingual-MiniLM-L12-v2
CHROMA_COLLECTION=documind_legal
CHROMA_HOST=
CHROMA_PORT=8000

INITIALIZE_RAG_ON_STARTUP=true
ENABLE_RERANKER=true

PRIMARY_LLM=groq/llama-3.3-70b-versatile
FALLBACK_LLM=gemini/gemini-1.5-flash
GROQ_API_KEY=replace_with_rotated_groq_key
GOOGLE_API_KEY=replace_with_rotated_google_key

# Keep disabled unless you add a real LangSmith key.
LANGCHAIN_TRACING_V2=false
LANGCHAIN_API_KEY=
LANGCHAIN_PROJECT=documind-ai
LANGCHAIN_ENDPOINT=https://api.smith.langchain.com

# Leave empty unless you add a Railway Redis service.
REDIS_URL=

DATA_DIR=./data
REPORTS_DIR=./reports
LOGS_DIR=./logs
SQLITE_DB=./data/documind.db

RATE_LIMIT_PER_MINUTE=10
MAX_UPLOAD_SIZE_MB=50
CHUNK_SIZE=512
CHUNK_OVERLAP=64
